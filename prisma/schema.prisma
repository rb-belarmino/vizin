// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Modelos MVP Vizin
// -----------------------------------------------------------------------------

model Unit {
  id        Int      @id @default(autoincrement())
  block     String
  number    String
  createdAt DateTime @default(now())

  users User[]

  @@unique([block, number])
}

model User {
  id        String   @id @default(uuid())
  fullName  String
  email     String   @unique
  password  String?
  role      String   @default("resident")
  createdAt DateTime @default(now())

  // Relacionamento com Unit (Morador pertence a uma Unidade)
  unitId Int
  unit   Unit @relation(fields: [unitId], references: [id])

  // Campos padrão exigidos/recomendados pelo NextAuth.js
  name          String? // O NextAuth mapeia 'name' por padrão para providers OAuth
  emailVerified DateTime?
  image         String?

  // Relacionamentos NextAuth
  accounts Account[]
  sessions Session[]
  services Service[]
}

// -----------------------------------------------------------------------------
// Modelos de Configuração do NextAuth.js (Prisma Adapter)
// -----------------------------------------------------------------------------

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Service {
  id          String  @id @default(uuid())
  title       String // ex: "Marmitas Congeladas da Maria"
  description String  @db.Text // ex: "Opções fit e low-carb de segunda a sexta."
  category    String // ex: "Alimentação", "Manutenção", "Aulas", etc
  contact     String? // Um número de WhatsApp público do serviço (se o usuário quiser)
  imageUrl    String? // Futura feature para o prestador subir a logo da marmita
  websiteUrl  String? // Futura feature para o prestador colocar um link externo (ex: Instagram, WhatsApp, etc)

  // Controle de Estado
  isActive  Boolean  @default(true) // O vizinho tirou férias? Pode desligar.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Quem está oferecendo o serviço? (Chave Estrangeira)
  providerId String
  provider   User   @relation(fields: [providerId], references: [id], onDelete: Cascade)
}
